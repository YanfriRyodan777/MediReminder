{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/landing",        "destination": "/landing.html"       },
    { "source": "/login",          "destination": "/inicio.html"        },
    { "source": "/inicio",         "destination": "/inicio.html"        },
    { "source": "/recordatorios",  "destination": "/recordatorios.html" },
    { "source": "/medicamentos",   "destination": "/medicamentos.html"  },
    { "source": "/monitoreo",      "destination": "/monitoreo.html"     },
    { "source": "/configuracion",  "destination": "/configuracion.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff"                        },
        { "key": "X-Frame-Options",        "value": "DENY"                           },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}